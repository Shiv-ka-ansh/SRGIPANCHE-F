{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the PANACHE 2K26 platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role for access control" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "A festival event.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Event title" },
        "description": { "type": "string", "description": "Detailed description" },
        "category": { "type": "string", "enum": ["Technical", "Cyber", "General", "Cultural"], "description": "Event category" },
        "date": { "type": "string", "format": "date-time", "description": "Event date and time" },
        "venue": { "type": "string", "description": "Location of the event" },
        "image": { "type": "string", "format": "uri", "description": "Cover image URL" },
        "maxCapacity": { "type": "number", "description": "Maximum allowed registrations" },
        "currentRegistrations": { "type": "number", "description": "Current number of approved registrations" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Event tags (e.g., Tech, Sports)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "createdBy": { "type": "string", "description": "Admin UID who created the event" }
      },
      "required": ["title", "description", "category", "date", "venue", "maxCapacity", "currentRegistrations", "createdAt", "createdBy"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A user's registration for an event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the registered user" },
        "eventId": { "type": "string", "description": "ID of the event" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Registration status" },
        "qrCodeData": { "type": "string", "description": "Unique data for QR code generation" },
        "registeredAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" }
      },
      "required": ["userId", "eventId", "status", "qrCodeData", "registeredAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Stores all festival events."
    },
    "/registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Stores event registrations."
    }
  }
}
